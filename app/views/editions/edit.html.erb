<h1>Update Edition</h1>
<%= simple_form_for @edition do |f| %>
  <%= f.association :season, value_method: :id, label_method: :years %>
  <%= f.association :competition, value_method: :id, label_method: :name %>
  <%= f.input :designation %>
	<%= f.input :letter %>
  <%= f.input :second_leg %>
  <%= f.button :submit, class: "btn btn-warning" %>
<% end -%>